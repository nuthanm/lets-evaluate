# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# App Configuration
APP_SECRET_KEY=your_secret_key_here_change_this
# Leave DATABASE_URL unset to use the default writable temp-dir SQLite database,
# or set it to an absolute path / PostgreSQL URL for persistent storage:
# DATABASE_URL=sqlite:////tmp/lets_evaluate.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Note: use a publicly-reachable hostname (e.g. a Supabase/Neon host), NOT a
# Docker Compose service name like "postgres" — that only resolves inside Docker.
